<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Status Window"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- TODO delete this gui example -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:background="#1E1E1E"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:text="[INFO] App started\n[INFO] Native library loaded: libservice.so\n[DEBUG] Heartbeat sent to 192.168.1.10\n[ERROR] Connection lost, retrying..."
        android:textColor="#00FF00"
        android:textSize="12sp" />

</LinearLayout>