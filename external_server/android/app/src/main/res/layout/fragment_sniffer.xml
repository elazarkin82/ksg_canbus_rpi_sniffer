<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CAN Traffic Monitor"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_group_by_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Group ID "
            android:checked="true"
            android:textOn=""
            android:textOff=""
            app:showText="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_sniffer"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLEAR" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Long-click for Protocol/PID. Double-click for Decoder Editor."
        android:textSize="10sp"
        android:textColor="@android:color/darker_gray" />

    <!-- Mock Table Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#DDDDDD"
        android:padding="4dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="ID" android:textStyle="bold" android:textSize="12sp"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="Count" android:textStyle="bold" android:textSize="12sp"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="Prot" android:textStyle="bold" android:textSize="12sp"/>
        <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="PID" android:textStyle="bold" android:textSize="12sp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Data (Hex)" android:textStyle="bold" android:textSize="12sp"/>
    </LinearLayout>

    <!-- Mock Table Rows -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:id="@+id/mock_table_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row 1 -->
            <LinearLayout
                android:id="@+id/mock_row_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal">
                <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="0x123" android:textSize="12sp"/>
                <TextView android:id="@+id/count_1" android:layout_width="50dp" android:layout_height="wrap_content" android:text="142" android:textSize="12sp"/>
                <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="OBD2" android:textSize="12sp"/>
                <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="0x0C" android:textSize="12sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="01 02 03 04 05 06 07 08" android:textSize="12sp" android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:id="@+id/mock_row_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal">
                <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="0x456" android:textSize="12sp"/>
                <TextView android:id="@+id/count_2" android:layout_width="50dp" android:layout_height="wrap_content" android:text="89" android:textSize="12sp"/>
                <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="Manual" android:textSize="12sp"/>
                <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="-" android:textSize="12sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="AA BB CC DD" android:textSize="12sp" android:fontFamily="monospace"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>